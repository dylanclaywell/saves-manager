# Pocket Quartermaster server configuration.
# Restart the server after editing this file:
#   Linux:   sudo systemctl restart pqm
#   Windows: close run.bat and reopen it

# Address to bind to.
#   0.0.0.0   = reachable from other devices on your network (default)
#   127.0.0.1 = local machine only
HOST=0.0.0.0

# TCP port to listen on. Pick anything 1024-65535 if 3000 conflicts.
PORT=3000
